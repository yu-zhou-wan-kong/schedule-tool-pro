<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 选中时显示浅色背景 -->
    <item android:state_checked="true" android:drawable="@drawable/bg_selected_item" />
    <item android:state_selected="true" android:drawable="@drawable/bg_selected_item" />
    <!-- 未选中时透明背景 -->
    <item android:drawable="@android:color/transparent" />
</selector>